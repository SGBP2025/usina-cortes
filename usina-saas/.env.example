# =============================================================
# USINA DE CORTES VIRAIS — Environment Variables
# Copie este arquivo para .env.local e preencha os valores
# NUNCA commite .env.local no repositório
# =============================================================

# --- Supabase ---
NEXT_PUBLIC_SUPABASE_URL=https://SEU_PROJETO.supabase.co
NEXT_PUBLIC_SUPABASE_ANON_KEY=eyJ...sua_anon_key
SUPABASE_SERVICE_ROLE_KEY=eyJ...sua_service_role_key

# --- IA ---
ANTHROPIC_API_KEY=sk-ant-...
OPENAI_API_KEY=sk-...

# --- Stripe ---
STRIPE_SECRET_KEY=sk_test_...
NEXT_PUBLIC_STRIPE_PUBLISHABLE_KEY=pk_test_...
STRIPE_WEBHOOK_SECRET=whsec_...

# --- Redis (para Bull queue) ---
# Local: redis://localhost:6379
# Upstash: rediss://...@...upstash.io:6379
REDIS_URL=redis://localhost:6379

# --- App ---
NEXT_PUBLIC_APP_URL=http://localhost:3000
NODE_ENV=development
